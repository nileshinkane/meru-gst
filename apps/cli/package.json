{
  "name": "@meru/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "meru": "./bin/meru",
    "meru-local": "./bin/meru-local"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:local": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:local": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dbffile": "^1.12.0",
    "terminal-kit": "^3.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
