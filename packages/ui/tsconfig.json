{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "paths": {
      "@meru/ui/*": ["./src/*"]
    }
  },
  "include": ["src", "postcss.config.mjs"],
  "exclude": ["node_modules", "dist"]
}
